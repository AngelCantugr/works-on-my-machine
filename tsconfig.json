{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "module": "ES2022",
    "lib": ["es2020"],
    "target": "es2019",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "baseUrl": ".",
    "paths": {
      "$": ["./src"],
      "$/*": ["./src/*"],
      "$components": ["./src/components"],
      "$components/*": ["./src/components/*"]
    },
    "types": ["astro/env"],
    "strictNullChecks": true
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*.astro",
    "src/**/*.d.ts",
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.md",
    "src/**/*.mdx",
    "src/pages/rss.xml.js"
  ]
}
